---
import BaseLayout from '../layouts/BaseLayout.astro';

const worksheets = [
  {
    id: 1,
    module: 1,
    title: "My Tarot Origin Story",
    description: "Explore what brought you to tarot, your hopes and intentions for this journey, and the wisdom you already carry.",
    emoji: "🌟",
    prompts: [
      "What first drew you to tarot?",
      "What do you hope to learn or gain from this course?",
      "How do you feel about using intuition as a tool for insight?",
      "Describe a time your intuition guided you well.",
      "What fears or doubts do you have about learning tarot?"
    ]
  },
  {
    id: 2,
    module: 2,
    title: "My Fool's Journey Map",
    description: "Chart your personal life journey through the lens of the 22 Major Arcana archetypes.",
    emoji: "🗺️",
    prompts: [
      "Which Major Arcana card best represents where you are RIGHT NOW in life?",
      "Which card represents a recent challenge you overcame?",
      "Which archetype do you most aspire to embody?",
      "Which archetype feels most foreign or challenging to you?",
      "Draw your own 'Fool's Journey' with 5 cards that tell your recent life story."
    ]
  },
  {
    id: 3,
    module: 2,
    title: "Archetype Mirror",
    description: "Explore how each of the 22 Major Arcana archetypes shows up in your personal life and relationships.",
    emoji: "🪞",
    prompts: [
      "Choose one Major Arcana card. How does this archetype show up in your daily life?",
      "Which archetype do people closest to you embody?",
      "What archetype are you currently being called to integrate?",
      "Describe a situation where you embodied the Magician (using your resources).",
      "Where in your life do you need more High Priestess energy (quiet inner knowing)?"
    ]
  },
  {
    id: 4,
    module: 3,
    title: "Elemental Self-Assessment",
    description: "Discover your elemental balance across Fire (Wands), Water (Cups), Air (Swords), and Earth (Pentacles).",
    emoji: "🔥",
    prompts: [
      "Rate each element in your life 1-10: Fire (passion/creativity), Water (emotions), Air (thoughts/communication), Earth (material/body).",
      "Which element do you feel most comfortable with?",
      "Which element do you most need to cultivate?",
      "How does each element show up in your work, relationships, and inner life?",
      "Pull one card from each suit. What does this 4-card spread tell you about your current elemental balance?"
    ]
  },
  {
    id: 5,
    module: 3,
    title: "Suit Balance Check-In",
    description: "A monthly check-in worksheet to see which suit energies are dominant or missing from your life.",
    emoji: "⚖️",
    prompts: [
      "Shuffle and draw 4 cards—one for each suit energy present in your life this month.",
      "Which suit is most active in your current situation?",
      "Which suit feels blocked or missing?",
      "What would bringing more balance to your elemental energies look like?",
      "Set one intention for each element for the coming month."
    ]
  },
  {
    id: 6,
    module: 4,
    title: "My Court Card Profile",
    description: "Identify which court card archetypes you embody in different areas of your life.",
    emoji: "👑",
    prompts: [
      "Which court card most represents your public persona?",
      "Which court card best reflects your inner emotional world?",
      "Which court card do you embody at work vs. in relationships?",
      "Which court card do you aspire to become?",
      "Which court card triggers or challenges you, and why?"
    ]
  },
  {
    id: 7,
    module: 5,
    title: "My Personal Spread Creation",
    description: "Design your own tarot spread to answer a question or explore an area of your life.",
    emoji: "🔮",
    prompts: [
      "What question or life area do you want to explore?",
      "How many cards do you want in your spread (3-7 recommended)?",
      "Name each position and what aspect of your question it addresses.",
      "Draw your spread layout here (sketch the positions).",
      "Perform the reading and journal the story the cards tell together."
    ]
  },
  {
    id: 8,
    module: 6,
    title: "Intuition Trust Journal",
    description: "A journal for tracking and validating your intuitive impressions to build confidence in your inner voice.",
    emoji: "⚡",
    prompts: [
      "Pull a card without looking up its meaning. What is your first intuitive impression?",
      "After journaling your impression, look up the traditional meaning. What matches?",
      "What symbols caught your eye first, and what do THEY mean to you personally?",
      "Describe a time your tarot intuition proved accurate or insightful.",
      "What does 'trusting your intuition' feel like in your body?"
    ]
  },
  {
    id: 9,
    module: 6,
    title: "My Reading Style Declaration",
    description: "Declare your unique approach to tarot reading and the values that will guide your practice.",
    emoji: "📜",
    prompts: [
      "How do I approach reversed cards in my readings?",
      "What is my reading philosophy (predictive, empowerment-based, psychological...)?",
      "What boundaries do I hold in my reading practice?",
      "How do I want people to FEEL after receiving a reading from me?",
      "Write your personal Reading Style Declaration in 3-5 sentences."
    ]
  },
  {
    id: 10,
    module: 7,
    title: "Reading for Others Reflection",
    description: "Reflect on your experience of reading tarot for others and refine your ethical approach.",
    emoji: "💫",
    prompts: [
      "How did it feel to read for someone else for the first time?",
      "What ethical guidelines feel most important to you as a reader?",
      "How do you handle it when someone receives a challenging card?",
      "What boundaries do you need to maintain to read sustainably?",
      "Write a 3-sentence ethics statement for your tarot practice."
    ]
  }
];
---
<BaseLayout title="Worksheets — The Fearless Tarot" description="Printable and interactive tarot journaling worksheets to deepen your tarot practice.">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <p class="font-accent text-violet text-sm uppercase tracking-widest mb-3">✦ Deepen Your Practice ✦</p>
      <h1 class="font-heading text-5xl sm:text-6xl text-moonlight mb-4"
          style="text-shadow: 0 0 20px rgba(123,104,238,0.6);">
        Worksheets & Journals
      </h1>
      <p class="text-silver/70 font-accent text-sm max-w-lg mx-auto">
        Ten guided worksheets to support your tarot learning journey. Use these for self-reflection, journaling, or group discussion.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {worksheets.map((ws) => (
        <div class="worksheet-card p-6 rounded-2xl border border-charcoal/40 bg-charcoal/10 hover:border-violet/40 transition-all group">
          <div class="flex items-start gap-4 mb-4">
            <div class="text-4xl">{ws.emoji}</div>
            <div>
              <p class="font-accent text-teal text-xs uppercase tracking-wider mb-1">Module {ws.module} Worksheet</p>
              <h2 class="font-heading text-xl text-moonlight group-hover:text-violet transition-colors">{ws.title}</h2>
            </div>
          </div>

          <p class="text-silver/70 text-sm leading-relaxed mb-4">{ws.description}</p>

          <details class="group/details">
            <summary class="font-accent text-violet text-xs uppercase tracking-wider cursor-pointer hover:text-teal transition-colors list-none flex items-center gap-1">
              <span class="transition-transform group-open/details:rotate-90">▶</span>
              View Journal Prompts
            </summary>
            <ul class="mt-3 space-y-2">
              {ws.prompts.map((prompt, i) => (
                <li class="flex gap-2 text-sm">
                  <span class="text-violet/60 font-accent text-xs mt-0.5">{i + 1}.</span>
                  <p class="text-silver/80 italic">{prompt}</p>
                </li>
              ))}
            </ul>
          </details>

          <div class="mt-4 pt-3 border-t border-charcoal/30 flex justify-between items-center">
            <span class="font-accent text-silver/40 text-xs">For personal use & journaling</span>
            <button
              onclick="window.print()"
              class="font-accent text-xs text-violet/60 hover:text-violet transition-colors no-print"
              aria-label="Print this worksheet"
            >
              🖨️ Print
            </button>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 p-6 rounded-2xl border border-teal/20 bg-teal/5 text-center">
      <p class="font-heading text-2xl text-teal mb-2">🌙 How to Use These Worksheets</p>
      <p class="text-silver/70 text-sm max-w-2xl mx-auto">
        These worksheets are designed to be used alongside each module. You can write directly in your journal, print them out, or use them as discussion guides in a group setting.
        There are no wrong answers — only your authentic responses.
      </p>
    </div>
  </div>
</BaseLayout>
